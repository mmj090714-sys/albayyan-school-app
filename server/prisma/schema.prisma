// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id             String        @id @default(uuid())
  name           String        @unique // e.g., "2026/2027"
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean       @default(false)
  terms          Term[]
  feeStructures  FeeStructure[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Term {
  id             String        @id @default(uuid())
  sessionId      String
  name           String        // e.g., "Term 1", "Term 2", "Term 3"
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean       @default(false)
  session        Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  feeStructures  FeeStructure[]
  invoices       Invoice[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([sessionId, name])
}

model Student {
  id               String        @id @default(uuid())
  admissionNumber  String        @unique
  firstName        String
  lastName         String
  school           String        @default("Secondary") // "Primary" or "Secondary"
  classLevel       String
  parentPhoneNumber String
  boardingStatus   Boolean       @default(false)
  takesSchoolBus   Boolean       @default(false)
  isNewStudent     Boolean       @default(true)
  joinedDate       DateTime      @default(now())
  invoices         Invoice[]
  carryForwards    CarryForward[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model FeeStructure {
  id                         String        @id @default(uuid())
  sessionId                  String
  termId                     String
  classLevel                 String
  // New Student Fees (per class)
  newStudentBaseTuition      Float        // Base tuition for new students
  newStudentBoardingFee      Float?       // Optional boarding fee
  newStudentSchoolBusFee     Float?       // Optional school bus fee
  newStudentTotal            Float        // Total: base + boarding + bus
  // Returning Student Fees (per class)
  returningStudentBaseTuition Float       // Base tuition for returning students
  returningStudentBoardingFee Float?      // Optional boarding fee
  returningStudentSchoolBusFee Float?     // Optional school bus fee
  returningStudentTotal      Float        // Total: base + boarding + bus
  session                    Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  term                       Term         @relation(fields: [termId], references: [id], onDelete: Cascade)
  invoices                   Invoice[]
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt

  @@unique([sessionId, termId, classLevel])
}

model Invoice {
  id                String        @id @default(uuid())
  studentId         String
  feeStructureId    String
  termId            String
  totalAmount       Float
  amountPaid        Float         @default(0.0)
  balanceDue        Float
  carriedForwardBalance Float      @default(0.0)
  dueDate           DateTime
  status            String        @default("Unpaid") // Unpaid, Partial, Paid
  isNewStudent      Boolean       // Captured at invoice time
  student           Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeStructure      FeeStructure  @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  term              Term          @relation(fields: [termId], references: [id], onDelete: Cascade)
  payments          Payment[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model CarryForward {
  id              String        @id @default(uuid())
  studentId       String
  fromTermId      String
  toTermId        String
  balanceAmount   Float
  status          String        @default("Active") // Active, Cleared, Partial
  appliedToInvoiceId String?
  student         Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Payment {
  id                   String   @id @default(uuid())
  invoiceId            String
  amountPaid           Float
  paymentMethod        String   // UBA, Sterling, Unity, Moniepoint, Cash
  bankName             String?  // Bank name if applicable
  receiptNumber        String   @unique
  paidByName           String   // Name of person who made the payment
  transactionReference String   @unique
  paymentDate          DateTime @default(now())
  recordedBy           String   // Admin ID or "System"
  invoice              Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}
