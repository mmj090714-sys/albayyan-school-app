{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "env": {
    "DATABASE_URL": "@DATABASE_URL",
    "JWT_SECRET": "@JWT_SECRET",
    "ADMIN_USERNAME": "@ADMIN_USERNAME",
    "ADMIN_PASSWORD": "@ADMIN_PASSWORD",
    "DIRECTOR_USERNAME": "@DIRECTOR_USERNAME",
    "DIRECTOR_PASSWORD": "@DIRECTOR_PASSWORD",
    "NODE_ENV": "production"
  }
}
